CREATE OR REPLACE VIEW v_integrated_payslip_summary AS
SELECT 
    e.employee_id AS `Emp ID`,
    CONCAT(e.first_name, ' ', e.last_name) AS `Full Name`,
    e.position AS `Role`,
    mps.`Total Days Worked` AS `Days Worked`,
    mps.`Total Hours Logged` AS `Hours Logged`,
    mps.`Total Tardy Minutes` AS `Late Mins`,
    
    -- Financial Gross Outflow mapping directly to profile base rates
    ROUND(mps.`Reg Hours` * e.hourly_rate, 2) AS `Base Earnings`,
    ROUND(mps.`OT Hours` * (e.hourly_rate * 1.5), 2) AS `Overtime Pay`,
    ROUND((e.rice_subsidy + e.phone_allowance + e.clothing_allowance) / 2, 2) AS `Semi-Monthly Allowances`,
    
    -- Minute-to-minute precise lateness tracking linked to specific hourly weightings
    ROUND(mps.`Total Tardy Minutes` * (e.hourly_rate / 60.0), 2) AS `Late Deductions`,
    
    -- Absolute Final Take-Home Net Paycheck calculation
    ROUND(
        (mps.`Reg Hours` * e.hourly_rate) + 
        (mps.`OT Hours` * (e.hourly_rate * 1.5)) + 
        ((e.rice_subsidy + e.phone_allowance + e.clothing_allowance) / 2) - 
        (mps.`Total Tardy Minutes` * (e.hourly_rate / 60.0)), 2
    ) AS `Net Semi-Monthly Pay`
FROM v_master_payroll_summary mps
JOIN employees e ON mps.`Employee ID` = e.employee_id;

SELECT * FROM v_integrated_payslip_summary;

SELECT 
    `Emp ID` AS `ID`,
    `Full Name`,
    `Role`,
    CONCAT('$', FORMAT(`Base Earnings`, 2)) AS `Regular Shift Earnings`,
    CONCAT('$', FORMAT(`Overtime Pay`, 2)) AS `Overtime (1.5x)`,
    CONCAT('$', FORMAT(`Semi-Monthly Allowances`, 2)) AS `Tax-Free Allowances`,
    CONCAT('-$', FORMAT(`Late Deductions`, 2)) AS `Tardiness Penalties`,
    CONCAT('$', FORMAT(`Net Semi-Monthly Pay`, 2)) AS `FINAL TAKE-HOME NET PAY`
FROM v_integrated_payslip_summary
WHERE `Emp ID` = 10012; -- Example: Josie Lopez

