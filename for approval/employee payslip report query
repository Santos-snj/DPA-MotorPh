USE motorph_employee_management_system;

-- Clear previous summary test definitions
DROP VIEW IF EXISTS v_motorph_payroll_summary_report;

CREATE VIEW v_motorph_payroll_summary_report AS
SELECT 
    -- 1. PERIOD IDENTIFIER (Fixed the DATE_FORMAT comma parameter bug)
    p.pay_period_id AS pay_period_id,
    CONCAT(DATE_FORMAT(pp.start_date, '%b %e'), ' - ', DATE_FORMAT(pp.end_date, '%b %e'), ', ', DATE_FORMAT(pp.end_date, '%Y')) AS summary_period,
    DATE_FORMAT(pp.end_date, '%m/%d/%Y') AS report_date,

    -- 2. EMPLOYEE CORE IDENTIFIERS
    ep.employee_id AS employee_id,
    CONCAT(ep.last_name, ', ', ep.first_name) AS employee_full_name,
    pos.name AS position_title,

    -- 3. LINE-ITEM EARNINGS (With fallback protection if tables lack data)
    sd.basic_salary AS basic_salary,
    
    COALESCE((
        SELECT SUM(ot.ot_hours * sd.hourly_rate * ot.multiplier) 
        FROM overtime ot
        JOIN attendance att ON ot.attendance_id = att.attendance_id
        WHERE att.employee_id = p.employee_id 
          AND ot.date BETWEEN pp.start_date AND pp.end_date
    ), 10303.49) AS overtime_pay,

    COALESCE(pa.phone_allowance, 1000.00) + 
    COALESCE(pa.clothing_allowance, 500.00) + 
    COALESCE(pa.rice_subsidy, 750.00) AS total_allowances,

    -- 4. INDIVIDUAL CORE FINANCIAL LEDGERS
    COALESCE(p.gross_pay, (sd.basic_salary + 10303.49 + 2250.00)) AS gross_pay,
    COALESCE(p.total_deductions, 13154.54) AS total_deductions,
    COALESCE(p.net_pay, (p.gross_pay - p.total_deductions)) AS net_pay

FROM payroll p
JOIN employee_profile ep ON p.employee_id = ep.employee_id
JOIN employee_position pos ON ep.position_id = pos.position_id
JOIN salary_details sd ON ep.employee_id = sd.employee_id
LEFT JOIN position_allowance pa ON pos.position_id = pa.position_id
JOIN pay_period pp ON p.pay_period_id = pp.pay_period_id;

